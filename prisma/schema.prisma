// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  CLIENT
}

enum MaterialKind {
  RECORDING
  PRESENTATION
  PDF
  EXTRA
}

enum CohortStatus {
  RECRUITING
  CURRENT
  COMPLETED
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  passwordHash String
  fullName     String
  phone        String?
  role         UserRole     @default(CLIENT)
  legalAcceptedAt DateTime?
  createdAt    DateTime     @default(now())
  sessions            Session[]
  enrollments         Enrollment[]
  employmentDocuments EmploymentDocument[]
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Cohort {
  id               String       @id @default(cuid())
  name             String
  description      String
  status           CohortStatus @default(RECRUITING)
  currentDayNumber Int          @default(1)
  createdAt        DateTime     @default(now())
  days             LearningDay[]
  enrollments      Enrollment[]
  news             News[]
}

model LearningDay {
  id          String         @id @default(cuid())
  cohortId    String
  dayNumber   Int
  slug        String
  title       String
  date        DateTime
  startAt     String
  description String
  meetingLink String
  agenda      String
  isCompleted Boolean        @default(false)
  createdAt   DateTime       @default(now())
  cohort      Cohort         @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  materials   LessonMaterial[]
  scheduleItems DayScheduleItem[]

  @@unique([cohortId, dayNumber])
  @@unique([cohortId, slug])
}

model DayScheduleItem {
  id            String      @id @default(cuid())
  learningDayId String
  startAt       String
  endAt         String
  title         String
  format        String
  sortOrder     Int         @default(0)
  learningDay   LearningDay @relation(fields: [learningDayId], references: [id], onDelete: Cascade)
}

model Enrollment {
  id        String   @id @default(cuid())
  userId    String
  cohortId  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cohort    Cohort   @relation(fields: [cohortId], references: [id], onDelete: Cascade)

  @@unique([userId, cohortId])
}

model LessonMaterial {
  id            String      @id @default(cuid())
  learningDayId String
  title         String
  href          String
  kind          MaterialKind
  isTrainerFeed Boolean     @default(false)
  addedAt       DateTime    @default(now())
  learningDay   LearningDay @relation(fields: [learningDayId], references: [id], onDelete: Cascade)
}

model News {
  id          String   @id @default(cuid())
  cohortId    String
  title       String
  description String
  publishedAt DateTime @default(now())
  cohort      Cohort   @relation(fields: [cohortId], references: [id], onDelete: Cascade)
}

model LibraryItem {
  id        String   @id @default(cuid())
  title     String
  category  String
  type      String
  href      String
  updatedAt DateTime @updatedAt
}

model EmploymentDocument {
  id           String   @id @default(cuid())
  userId       String
  title        String
  description  String
  previewHref  String
  downloadHref String
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CareerManager {
  id          String   @id @default(cuid())
  name        String
  role        String
  about       String
  photo       String
  telegramTag String
  maxTag      String
  updatedAt   DateTime @updatedAt
}
